<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="oval">
            <solid android:color="#15F5C842"/>
            <stroke
                android:width="1dp"
                android:color="#35F5C842"/>
        </shape>
    </item>

    <item
        android:left="10dp"
        android:right="10dp"
        android:top="10dp"
        android:bottom="10dp">

        <shape android:shape="oval">
            <solid android:color="#25F5C842"/>
            <stroke
                android:width="1dp"
                android:color="#55F5C842"/>
        </shape>

    </item>

</layer-list>