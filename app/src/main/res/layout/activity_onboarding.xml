<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_skip_pill"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:text="Skip"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
        android:id="@+id/dots_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/tvTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        app:dotsColor="#80FFFFFF"
        app:dotsSize="8dp"
        app:dotsSpacing="6dp"
        app:dotsWidthFactor="2.5"
        app:progressMode="false"
        app:selectedDotColor="#FFFFFF" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/tvDescription"
        android:layout_centerHorizontal="true"
        android:fontFamily="sans-serif-black"
        android:text="Daily Motivation"
        android:textAlignment="center"
        android:textColor="@color/app_text"
        android:textSize="32sp" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/btnContinue"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:alpha="0.8"
        android:paddingHorizontal="20dp"
        android:textAlignment="center"
        android:textColor="@color/app_text"
        android:textSize="18sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:backgroundTint="#F2D161"
        android:text="Continue"
        android:textAllCaps="false"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="24dp" />

</RelativeLayout>