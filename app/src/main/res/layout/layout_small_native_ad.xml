<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.tools.com/tools"
    android:id="@+id/nativeAdView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#1C1C1E">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="10dp"
            android:paddingVertical="10dp">

            <ImageView
                android:id="@+id/ad_icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_icon_rounded"
                android:contentDescription="Ad Icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:src="@tools:sample/avatars" />

            <LinearLayout
                android:id="@+id/headline_row"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                app:layout_constraintTop_toTopOf="@id/ad_icon"
                app:layout_constraintStart_toEndOf="@id/ad_icon"
                app:layout_constraintEnd_toStartOf="@id/ad_call_to_action">

                <TextView
                    android:id="@+id/ad_attribution"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_ad_tag"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="1dp"
                    android:text="AD"
                    android:textColor="#AAAAAA"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/ad_headline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="Service Desk" />

            </LinearLayout>

            <TextView
                android:id="@+id/ad_body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:layout_marginStart="10dp"
                android:ellipsize="end"
                android:layout_marginEnd="10dp"
                android:maxLines="2"
                android:textColor="#9A9A9A"
                android:textSize="11sp"
                app:layout_constraintTop_toBottomOf="@id/headline_row"
                app:layout_constraintStart_toEndOf="@id/ad_icon"
                app:layout_constraintEnd_toStartOf="@id/ad_call_to_action"
                tools:text="Remote | Other Roles" />

            <TextView
                android:id="@+id/ad_advertiser"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginStart="10dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#7A7A7A"
                android:textSize="9sp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/ad_body"
                app:layout_constraintStart_toEndOf="@id/ad_icon"
                app:layout_constraintEnd_toStartOf="@id/ad_call_to_action"
                tools:text="Advertiser Name" />

            <TextView
                android:id="@+id/ad_call_to_action"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:minWidth="70dp"
                android:background="@drawable/bg_cta_pill"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:clickable="true"
                android:focusable="true"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="@id/ad_icon"
                app:layout_constraintBottom_toBottomOf="@id/ad_icon"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="APPLY" />

            <com.google.android.gms.ads.nativead.MediaView
                android:id="@+id/ad_media"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="invisible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</com.google.android.gms.ads.nativead.NativeAdView>