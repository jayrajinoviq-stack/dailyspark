<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.fragment.ExploreFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/title_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:text="Explore"
            android:textSize="22dp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/searchContainer"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="16dp"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="22dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title_text">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/search"
                android:tint="@color/text_primary" />

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Search quotes..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:textSize="16sp" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/close_btn"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/close"
                android:tint="@color/text_primary"
                android:visibility="gone" />

        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/rvCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="15dp"
            android:scrollbars="none"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/searchContainer">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvCatAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_categories_cap"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="4dp"
                    android:text="All"
                    android:textColor="@color/text_primary" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvCatMotivation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_category_normal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="4dp"
                    android:text="Motivation"
                    android:textColor="@color/text_primary" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvCatLove"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_category_normal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="4dp"
                    android:text="Love"
                    android:textColor="@color/text_primary" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvCatWisdom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_category_normal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="4dp"
                    android:text="Wisdom"
                    android:textColor="@color/text_primary" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvCatFriendship"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_category_normal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="4dp"
                    android:text="Friendship"
                    android:textColor="@color/text_primary" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvCatFunny"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_category_normal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="4dp"
                    android:text="funny"
                    android:textColor="@color/text_primary" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvCatLife"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_category_normal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="4dp"
                    android:text="Life"
                    android:textColor="@color/text_primary" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvCatSuccess"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_category_normal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="4dp"
                    android:text="Success"
                    android:textColor="@color/text_primary" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvCatHappiness"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_category_normal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="4dp"
                    android:text="Happiness"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/text_my_categories"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="18dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rvCategories">

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/my_categories"
                android:textSize="16dp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/add_btn"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:background="@drawable/add_icon_bg"
                android:padding="8dp"
                android:src="@drawable/add"
                android:tint="@color/accent" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/rvCategoriesLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_my_categories">


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFolders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_folder_card" />


        </LinearLayout>


        <LinearLayout
            android:id="@+id/layoutRetry"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:paddingVertical="48dp"
            android:layout_marginHorizontal="18dp"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rvCategoriesLayout"
            app:layout_constraintBottom_toBottomOf="parent"
            android:gravity="center"
            android:orientation="vertical">


            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Internet Connection"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/accent"
                android:text="Retry"
                android:textColor="@color/app_text" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvList"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rvCategoriesLayout"
            app:layout_constraintVertical_bias="1.0"
            tools:listitem="@layout/item_quote" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rvCategories" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvEmptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Empty State"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rvCategories" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>