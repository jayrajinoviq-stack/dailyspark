<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/shimmerLayout"
    android:layout_width="match_parent"
    android:background="@color/black"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:cardBackgroundColor="#1C1C1E"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="10dp"
            android:paddingVertical="10dp">

            <View
                android:id="@+id/shimmer_icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_icon_rounded"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <LinearLayout
                android:id="@+id/shimmer_headline_row"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toStartOf="@id/shimmer_cta"
                app:layout_constraintStart_toEndOf="@id/shimmer_icon"
                app:layout_constraintTop_toTopOf="@id/shimmer_icon">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_ad_tag"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="1dp"
                    android:text="AD"
                    android:textSize="9dp" />

                <View
                    android:layout_width="90dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_icon_rounded" />

            </LinearLayout>

            <View
                android:id="@+id/shimmer_body"
                android:layout_width="130dp"
                android:layout_height="10dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_icon_rounded"
                app:layout_constraintStart_toEndOf="@id/shimmer_icon"
                app:layout_constraintTop_toBottomOf="@id/shimmer_headline_row" />


            <View
                android:id="@+id/shimmer_advertiser"
                android:layout_width="80dp"
                android:layout_height="8dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_icon_rounded"
                app:layout_constraintStart_toEndOf="@id/shimmer_icon"
                app:layout_constraintTop_toBottomOf="@id/shimmer_body" />

            <!-- CTA placeholder -->
            <View
                android:id="@+id/shimmer_cta"
                android:layout_width="70dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_cta_pill"
                app:layout_constraintBottom_toBottomOf="@id/shimmer_icon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/shimmer_icon" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</com.facebook.shimmer.ShimmerFrameLayout>